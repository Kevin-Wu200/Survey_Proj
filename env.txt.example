# =============================================================================
# 空地协同无人化智能测绘系统 - 环境配置模板
# 
# 使用方法: 复制此文件为 env.txt 并填入实际配置值
#   cp env.txt.example env.txt
# =============================================================================

# 高德地图 JS API 密钥 (v2.0)
# 获取地址: https://console.amap.com/dev/key/app
AMAP_KEY=your_amap_key_here

# 前端开发服务器 (Vite)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# 后端 API 服务 (FastAPI + uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 地图默认中心点经纬度
CENTER_LAT=30.0
CENTER_LNG=120.0
