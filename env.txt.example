FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# 后端 API 服务 (FastAPI + uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 地图默认中心点经纬度
CENTER_LAT=0.0
CENTER_LNG=0.0
