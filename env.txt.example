# =============================================================================
# 空地协同无人化智能测绘系统 - 环境配置模板
# 
# 使用方法: 复制此文件为 env.txt 并填入实际配置值
#   cp env.txt.example env.txt
# =============================================================================

# 前端开发服务器 (Vite)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# 后端 API 服务 (FastAPI + uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 地图默认中心点经纬度
CENTER_LAT=0.0
CENTER_LNG=0.0

# 地图默认缩放级别 (3-18)
MAP_ZOOM=5

# =============================================================================
# 数据库配置 (PostgreSQL 15 + PostGIS 3)
# =============================================================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=air_survey_db
DB_USER=air_survey
DB_PASSWORD=your_password_here
